<!DOCTYPE html>
<html>
<head>
  <title>Edit Produk</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    body{ background:#f4f7fb }

    .card{
      border:none;
      border-radius:14px;
    }

    .navbar{
      background: linear-gradient(90deg, #0d6efd, #0b5ed7);
    }

    .navbar-brand{
      color:white;
      font-weight:bold;
    }

    .img-preview{
      width:120px;
      border-radius:10px;
      border:1px solid #ddd;
      padding:5px;
      background:white;
    }
  </style>
</head>

<body>

<nav class="navbar mb-4">
  <div class="container">
    <span class="navbar-brand">Edit Produk</span>
  </div>
</nav>

<div class="container">
  <div class="card shadow p-4">

    <form action="/admin/update/<%= p.kode_barang %>" method="POST" enctype="multipart/form-data">

      <div class="mb-3">
        <label>Nama Barang</label>
        <input name="nama_barang" value="<%= p.nama_barang %>" class="form-control" required>
      </div>

      <div class="mb-3">
        <label>Deskripsi</label>
        <textarea name="deskripsi" class="form-control"><%= p.deskripsi %></textarea>
      </div>

      <div class="row">
        <div class="col-md-6 mb-3">
          <label>Harga Modal</label>
          <input name="harga_modal" type="number" value="<%= p.harga_modal %>" class="form-control" required>
        </div>

        <div class="col-md-6 mb-3">
          <label>Harga Jual</label>
          <input name="harga" type="number" value="<%= p.harga %>" class="form-control" required>
        </div>
      </div>

      <div class="mb-3">
        <label>Stok</label>
        <input name="stok" type="number" value="<%= p.stok %>" class="form-control" required>
      </div>

      <div class="mb-3">
        <label>Kategori</label>
        <select name="kategori_id" class="form-select">
          <% kategori.forEach(k => { %>
            <option value="<%= k.id %>" <%= p.kategori_id==k.id?'selected':'' %>>
              <%= k.nama_kategori %>
            </option>
          <% }) %>
        </select>
      </div>

      <div class="mb-3">
        <label>Gambar Saat Ini</label><br>
        <% if(p.gambar){ %>
          <img src="/uploads/<%= p.gambar %>" class="img-preview mb-2">
        <% } else { %>
          <p class="text-muted">Belum ada gambar</p>
        <% } %>
      </div>

      <div class="mb-4">
        <label>Ganti Gambar</label>
        <input type="file" name="gambar" class="form-control">
      </div>

      <button class="btn btn-primary">Update</button>
      <a href="/admin" class="btn btn-secondary">Kembali</a>

    </form>
  </div>
</div>

</body>
</html>