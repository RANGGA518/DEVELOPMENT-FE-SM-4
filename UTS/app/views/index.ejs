<!DOCTYPE html>
<html>
<head>
  <title>Admin Minimarket</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    body{ background:#f4f7fb }

    .card{
      border:none;
      border-radius:12px;
    }

    .navbar{
      background: linear-gradient(90deg, #0d6efd, #0b5ed7);
    }

    .navbar-brand{
      color:white;
      font-weight:bold;
      font-size:18px;
    }

    .table thead{
      background:#0d6efd;
      color:white;
    }

    .btn-primary{
      background:#0d6efd;
    }

    .table img{
      border-radius:6px;
      border:1px solid #ddd;
      padding:3px;
      background:white;
    }

    .search-box{
      width:250px;
    }

    .badge{
      font-size:14px;
    }
  </style>
</head>

<body>

<nav class="navbar mb-4">
  <div class="container d-flex justify-content-between">
    <span class="navbar-brand">Dashboard Admin Minimarket</span>
    <a href="/admin/add" class="btn btn-light">+ Tambah Produk</a>
  </div>
</nav>

<div class="container">
  <div class="card shadow p-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
      <h4>Daftar Produk</h4>

      <form method="GET" action="/admin">
        <input type="text" name="search" class="form-control search-box" placeholder="Cari produk...">
      </form>
    </div>

    <table class="table table-bordered table-hover align-middle">
      <thead>
        <tr>
          <th>Kode</th>
          <th>Nama Barang</th>
          <th>Deskripsi</th>
          <th>Harga Modal</th>
          <th>Harga Jual</th>
          <th>Stok</th>
          <th>Gambar</th>
          <th width="170">Aksi</th>
        </tr>
      </thead>

      <tbody>
        <% if(produk.length === 0){ %>
          <tr>
            <td colspan="8" class="text-center text-muted">Data tidak ditemukan</td>
          </tr>
        <% } %>

        <% produk.forEach(p => { %>
          <tr>
            <td><%= p.kode_barang %></td>
            <td><strong><%= p.nama_barang %></strong></td>
            <td><%= p.deskripsi %></td>

            <td>Rp <%= Math.round(p.harga_modal).toLocaleString("id-ID") %></td>
            <td><b>Rp <%= Math.round(p.harga).toLocaleString("id-ID") %></b></td>

            <td>
              <span class="badge bg-primary"><%= p.stok %></span>
            </td>

            <td>
              <% if(p.gambar){ %>
                <img src="/uploads/<%= p.gambar %>" width="60">
              <% } else { %>
                <span class="text-muted">-</span>
              <% } %>
            </td>

            <td>
              <a href="/admin/edit/<%= p.kode_barang %>" class="btn btn-sm btn-warning">Edit</a>

              <a href="/admin/delete/<%= p.kode_barang %>" 
                 class="btn btn-sm btn-danger"
                 onclick="return confirm('Yakin hapus produk ini?')">
                 Hapus
              </a>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>

  </div>
</div>

</body>
</html>